{
  "name": "cutout-studio",
  "version": "0.1.0",
  "description": "Cutout Studio: portrait background removal with a lightweight TypeScript web app and safety controls.",
  "type": "module",
  "bin": {
    "remove-background": "./src/cli.js"
  },
  "scripts": {
    "build": "vite build",
    "dev": "concurrently -k \"npm:dev:server\" \"npm:dev:client\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "deploy:preflight": "node scripts/deploy-preflight.mjs",
    "start": "node server/index.js",
    "test": "node --test"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "connect-pg-simple": "^10.0.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "multer": "^2.0.2",
    "ndarray": "^1.0.19",
    "onnxruntime-node": "^1.22.0",
    "openai": "^6.46.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "pg": "^8.22.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "sharp": "^0.34.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.3",
    "@types/express-session": "^1.18.2",
    "@types/multer": "^1.4.12",
    "@types/node": "^24.0.13",
    "@types/passport": "^1.0.17",
    "@types/passport-github2": "^1.2.9",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^5.0.2",
    "concurrently": "^9.1.2",
    "playwright-core": "^1.61.1",
    "supertest": "^7.2.2",
    "typescript": "^5.8.3",
    "vite": "^7.1.4"
  }
}
